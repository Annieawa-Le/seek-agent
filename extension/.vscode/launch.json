{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Seek AI IDE - 扩展开发",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}/.."
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "Build extension"
    }
  ]
}
